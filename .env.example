# LOCAL MODE (current): no environment variables needed. Edits write to files.

# GITHUB MODE (only when you flip storage.kind to "github" — see README):
# Provide these via Cloudflare Pages env vars / your keychain. NEVER commit real values.
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=                  # random 32-byte hex (e.g. `openssl rand -hex 32`)
# PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=  # public — the GitHub App's slug
