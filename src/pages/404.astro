---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page not found">
  <section class="mx-auto max-w-content px-4 py-24 text-center sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-wide text-brand">404</p>
    <h1 class="mt-2 text-4xl">We couldn't find that page</h1>
    <p class="mt-3 text-navy/70">The link may be broken or the page may have moved.</p>
    <a
      href="/"
      class="mt-8 inline-flex min-h-[44px] items-center rounded-lg bg-brand px-5 py-3 font-semibold text-white transition hover:bg-brand-600"
    >
      Back home
    </a>
  </section>
</Layout>
