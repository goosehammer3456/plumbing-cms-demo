---
// Inline SVG icons keyed to the `icon` select in keystatic.config.ts.
// No emojis in UI (per design standards) — these are real vector icons.
interface Props {
  name: string;
  class?: string;
}
const { name, class: className = "h-6 w-6" } = Astro.props;
---

{
  name === "droplet" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path d="M12 3s6 6.5 6 11a6 6 0 1 1-12 0c0-4.5 6-11 6-11Z" stroke-linejoin="round" />
    </svg>
  )
}
{
  name === "flame" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path d="M12 3c1 3 4 4 4 8a4 4 0 0 1-8 0c0-1 .5-2 1-2.5C9 9 9 6 12 3Z" stroke-linejoin="round" />
    </svg>
  )
}
{
  name === "pipe" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path d="M4 8h7v8H4zM13 8h7v8h-7zM11 6v4M13 14v4" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
{
  name === "alert" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path d="M12 4 2.5 20h19L12 4Z" stroke-linejoin="round" />
      <path d="M12 10v4M12 17h.01" stroke-linecap="round" />
    </svg>
  )
}
{
  name === "sparkle" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path d="M12 3v6M12 15v6M3 12h6M15 12h6" stroke-linecap="round" />
    </svg>
  )
}
{
  (name === "wrench" || !["droplet", "flame", "pipe", "alert", "sparkle"].includes(name)) && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path d="M14.5 6.5a3.5 3.5 0 0 1-4.6 4.6L5 16v3h3l4.9-4.9a3.5 3.5 0 0 0 4.6-4.6l-2.1 2.1-2.1-.6-.6-2.1 2.1-2.1Z" stroke-linejoin="round" />
    </svg>
  )
}
