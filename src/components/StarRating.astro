---
interface Props {
  rating: number;
}
const { rating } = Astro.props;
const full = Math.max(0, Math.min(5, Math.round(rating)));
---

<div class="flex items-center gap-0.5" role="img" aria-label={`${full} out of 5 stars`}>
  {
    Array.from({ length: 5 }).map((_, i) => (
      <svg
        class={`h-4 w-4 ${i < full ? "text-copper" : "text-navy/15"}`}
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L10 14.9l-5.2 2.7 1-5.8L1.5 7.7l5.9-.9L10 1.5z" />
      </svg>
    ))
  }
</div>
